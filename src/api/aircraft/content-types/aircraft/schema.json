{
  "kind": "collectionType",
  "collectionName": "aircrafts",
  "info": {
    "singularName": "aircraft",
    "pluralName": "aircrafts",
    "displayName": "aircraft",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "yearOfFirstFlight": {
      "type": "date",
      "required": false
    },
    "type": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::aircarft-type.aircarft-type",
      "inversedBy": "aircraft"
    },
    "operator": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::operator.operator",
      "inversedBy": "aircraft"
    },
    "yearOfConstruction": {
      "type": "biginteger",
      "required": true,
      "max": "9999",
      "default": "2000"
    },
    "registration": {
      "type": "string",
      "required": false,
      "unique": false,
      "regex": "^[a-zA-Z0-9-]+$"
    },
    "serviceNumber": {
      "type": "string",
      "regex": "^[a-zA-Z0-9-]+$"
    }
  }
}
